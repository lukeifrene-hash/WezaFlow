{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WezaFlow",
  "version": "0.1.0",
  "identifier": "localflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WezaFlow",
        "width": 980,
        "height": 680,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "visible": true
      },
      {
        "label": "recording-bar",
        "title": "WezaFlow Recording",
        "width": 300,
        "height": 72,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
